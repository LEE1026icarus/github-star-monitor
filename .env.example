# Discord Webhook URL (필수)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# GitHub Personal Access Token (필수 — repo 상세 조회용)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub 결과 저장소 (ai-team-results clone 경로)
RESULTS_REPO_PATH=/home/ubuntu/ai_team/workspace/ai-team-results

# 실행 모드 (dry-run 시 실제 API 호출만 하고 push/send 생략)
DRY_RUN=false
